# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it contains secrets.

# Supabase — project URL and anon key are safe to share (public by design)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only keys, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Resend — email delivery API key
NEXUSBRIDGE_PORTAL_KEY=

# Upstash Redis — rate limiting store
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
